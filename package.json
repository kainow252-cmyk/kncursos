{
  "name": "kncursos",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=kncursos --local --ip 0.0.0.0 --port 3000",
    "build:css": "npx tailwindcss -i ./src/styles.css -o ./public/static/styles.css --minify",
    "build": "vite build",
    "preview": "wrangler pages dev",
    "deploy": "npm run build && wrangler pages deploy dist --project-name kncursos",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply kncursos --local",
    "db:migrate:prod": "wrangler d1 migrations apply kncursos",
    "db:seed": "wrangler d1 execute kncursos --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true"
  },
  "dependencies": {
    "hono": "^4.12.7",
    "pdfmake": "^0.3.6",
    "resend": "^6.9.3"
  },
  "devDependencies": {
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.1",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
